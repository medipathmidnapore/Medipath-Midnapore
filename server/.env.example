# Server Environment Variables
# Copy this file to .env and fill in your actual values

# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ──────────────────────────────────────
# Get your connection string from: mongodb.com → Clusters → Connect
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/medipath?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────
# Use a long random string (min 32 chars). Generate at: randomkeygen.com
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY
JWT_EXPIRES_IN=7d

# ─── Admin Login ────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@123

# ─── Cloudinary ─────────────────────────────────────────
# Sign up free at: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Webhook Security ───────────────────────────────────
# Share this secret with the hospital LIS team.
# They must send it as the x-webhook-secret header on every sync call.
WEBHOOK_SECRET=changeme_use_a_long_random_string

# ─── Client URL (for CORS) ──────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Main Server (GetCharge) ──────────────────────────────
# Single API endpoint — all operations use api_type parameter
MAIN_SERVER_URL=https://www.getcharge.in/medipath/web/api
MAIN_SERVER_SECRET_KEY=your_secret_key_from_getcharge

# ─── Google reCAPTCHA ───────────────────────────────────
# Get this from https://www.google.com/recaptcha/admin/create
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Production example:
# CLIENT_URL=https://your-app.vercel.app
